# CodePulse Environment Variables
# Copy this file to .env and fill in your API keys.

# Google Gemini API key (required when llm analyzer is enabled with google_genai provider)
GEMINI_API_KEY=your-gemini-api-key-here

# OpenAI API key (optional — if using openai provider)
# OPENAI_API_KEY=your-openai-api-key-here

# Anthropic API key (optional — if using anthropic provider)
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# SonarQube token (optional — if using sonarqube analyzer)
# SONAR_TOKEN=your-sonarqube-token-here

# LangSmith API key (optional — for observability)
# LANGSMITH_API_KEY=your-langsmith-api-key-here
